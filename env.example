# Use this file as a checklist for the IDs you need to gather before 
# setting up the nodes in the n8n Workflow JSON.

# Airtable
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_airtable_token_here
AIRTABLE_BASE_ID=your_base_id_here       # e.g. appXXXXXXXXXXXXXX
AIRTABLE_TABLE_ID=your_table_id_here     # e.g. tblXXXXXXXXXXXXXX
 
# Google OAuth2 (Gmail API + Google Sheets API)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5678/rest/oauth2-credential/callback
 
# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here         # Found in the sheet URL
GOOGLE_SHEET_NAME=Form Responses 1                # Tab name where form responses are stored
 
# Gmail
GMAIL_SEND_AS=your_email@gmail.com                # The Gmail address used to create drafts
 
# n8n (self-hosted)
N8N_HOST=localhost
N8N_PORT=5678
