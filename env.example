# n8n Workflow Configuration - Ascend IU Email Automation
# Copy this file to .env and fill in your own IDs

# --- AIRTABLE ---
# Found in the Airtable URL: airtable.com/appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=your_base_id_here

# Found in the Airtable URL when the table is open: airtable.com/app.../tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_ID=your_table_id_here

# --- GOOGLE SHEETS ---
# Found in the URL of your Google Sheet: docs.google.com/spreadsheets/d/XXXXXXXXXXXXXX/
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# --- GMAIL ---
# (Note: Gmail usually requires setting up an OAuth Credentials in n8n settings)
GMAIL_SENDER_EMAIL=your-email@gmail.com

# --- LINKS ---
# The links you want to include in your automated emails
INTEREST_FORM_LINK=https://forms.gle/your-link
FEEDBACK_FORM_LINK=https://forms.gle/your-feedback-link
